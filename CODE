#include <stdio.h>
#include <stdlib.h>

#define MAX 50

int queue[MAX];
int front = -1, rear = -1;

// Add vehicle
void enqueue(int vehicle) {
    if (rear == MAX - 1) {
        printf("Traffic Jam! Queue Full\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = vehicle;
    printf("Vehicle %d entered the queue\n", vehicle);
}

// Remove vehicle
void dequeue() {
    if (front == -1 || front > rear) {
        printf("No vehicles waiting\n");
        return;
    }

    printf("Vehicle %d passed the signal\n", queue[front]);
    front++;
}

// Display queue
void display() {
    if (front == -1 || front > rear) {
        printf("No vehicles in queue\n");
        return;
    }

    printf("Vehicles in queue: ");
    for (int i = front; i <= rear; i++) {
        printf("%d ", queue[i]);
    }
    printf("\n");
}

// Traffic signal simulation
void trafficSignal() {
    int choice, vehicle = 1;

    while (1) {
        printf("\n1.Vehicle Arrives\n2.Green Signal (Pass Vehicle)\n3.Show Queue\n4.Exit\n");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                enqueue(vehicle++);
                break;
            case 2:
                dequeue();
                break;
            case 3:
                display();
                break;
            case 4:
                exit(0);
            default:
                printf("Invalid choice\n");
        }
    }
}

int main() {
    printf("Traffic Light Management System\n");
    trafficSignal();
    return 0;
}
